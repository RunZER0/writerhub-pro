# Database - Neon PostgreSQL
DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# JWT Secret (generate a random string - use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# VAPID Keys for Web Push Notifications
# Generate your own keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Telegram Bot (Optional - for backup notifications)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=YourBotUsername

# Brevo Email API (for email verification)
# Get your API key from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=noreply@yourdomain.com

# Base URL (used for email verification links)
BASE_URL=https://www.homeworkpal.online

# Paystack (payment processing)
# Get your keys from: https://dashboard.paystack.com -> Settings -> API Keys & Webhooks
PAYSTACK_SECRET_KEY=REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=REPLACE_WITH_YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_CURRENCY=NGN

# Writenix (Turnitin-style plagiarism/AI report checker)
# Get your API key + webhook secret from your Writenix developer dashboard
WRITENIX_API_KEY=wrx_xxxxxxxxxxxxxxxxxxxx
WRITENIX_WEBHOOK_SECRET=your-writenix-webhook-secret

# App Configuration
PORT=3000
NODE_ENV=production
